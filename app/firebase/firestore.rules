rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isOperator() {
      return hasRole('operator') || hasRole('supervisor');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isSupervisor() {
      return hasRole('supervisor') || hasRole('control_room_manager') || hasRole('admin');
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isOperator() || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Alerts collection
    match /alerts/{alertId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isOperator() ||
        isAdmin()
      );
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isOperator() ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Control rooms collection
    match /controlRooms/{roomId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();

      // Cameras subcollection
      match /cameras/{cameraId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAdmin();
      }
    }

    // Operators collection
    match /operators/{operatorId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isOperator() ||
        isAdmin()
      );
      allow create, update: if isAdmin() || isSupervisor();
      allow delete: if isAdmin();
    }

    // Incidents collection
    match /incidents/{incidentId} {
      allow read: if isOperator() || isAdmin();
      allow create: if isOperator();
      allow update: if isOperator() || isAdmin();
      allow delete: if isAdmin();
    }

    // Welfare bookings collection
    match /welfareBookings/{bookingId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isOperator() ||
        isAdmin()
      );
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isOperator() || isAdmin();
      allow delete: if isAdmin();
    }

    // System settings (admin only)
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Analytics/stats (operators and admin can read)
    match /stats/{statId} {
      allow read: if isOperator() || isAdmin();
      allow write: if isAdmin();
    }
  }
}
